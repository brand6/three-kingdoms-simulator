{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "D:/Projects/Godot/三国模拟器/.opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "D:/Projects/Godot/三国模拟器/.opencode/get-shit-done/*": "allow"
    }
  },
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "command": {
    "update": {
      "agent": "document",
      "description": "update agent.md",
      "template": "Please analyze this codebase and update the AGENTS.md file containing:\n1. Build/lint/test commands - especially for running a single test\n2. Code style guidelines including imports, formatting, types, naming conventions, error handling, etc.\nThe file will be given to agentic coding agents (such as yourself) that operate in this repository. Make it about 150 lines long."
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "$CONTEXT7_API_KEY"
      }
    },
    "godot": {
      "type":"local",
      "command": ["npx","-y","@coding-solo/godot-mcp"],
      "environment": {
        "GODOT_PATH": "D:/Godot/Godot_v4.6.1-stable_mono_win64t",
        "DEBUG": "true"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=$TAVILY_API_KEY"
    }
  }
}
