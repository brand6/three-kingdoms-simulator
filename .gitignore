# Repository-level .gitignore

# Godot editor generated and temporary files
/.import/
*.import
*.import/*
.godot/
.mono/
*.log
debug.log
export_presets.cfg.user

# Godot editor UID files (editor-generated identifiers) - keep source assets tracked
**/*.uid

# OS files
Thumbs.db
ehthumbs.db
desktop.ini

# Node/Editor backups
*.swp
*.tmp

# Visual Studio / Rider
/.idea/
/.vs/

# token
broker-server-token.txt